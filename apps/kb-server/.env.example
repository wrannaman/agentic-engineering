# KB Server Configuration

# Storage — swap between SQLite and Postgres with one line:
DATABASE_URL=sqlite:///kb.db
# DATABASE_URL=postgresql://kb:kb@localhost:5432/kb

# Auth — bearer token for MCP and API access (leave empty for open access)
KB_AUTH_TOKEN=change-me-to-a-strong-random-string

# Repos — three ways to configure (pick one):
#
# Option 1: Comma-separated name:path pairs (local or remote)
REPOS=frontend:/path/to/frontend-kb,backend:/path/to/backend-kb
#
# Option 2: JSON for full control
# REPOS_JSON=[{"name":"frontend","path":"/path/to/frontend-kb"},{"name":"backend","path":"https://github.com/org/backend-kb.git","branch":"main"}]
#
# Option 3: Single repo (backwards compatible)
# REPO_URL=https://github.com/your-org/kb-docs.git
# REPO_BRANCH=main

# GH_TOKEN=ghp_xxx                  # only needed for PRIVATE GitHub repos. Not needed for local paths or public repos.
SYNC_INTERVAL_SECONDS=300          # 5 minutes

# Server
PORT=8080
HOST=0.0.0.0
